# ==============================================================================
# Reglas locales personalizadas para el IDS Snort 3
# Ruta sugerida de colocación: /etc/snort/rules/local.rules
# Autor: Iván
# ==============================================================================

# 1. Regla para detectar solicitudes de ping (ICMP Echo Request)
# Alerta cuando se recibe un paquete ICMP desde cualquier origen hacia nuestra red interna
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping Detectado"; sid:1000001; rev:1;)

# 2. Regla para detectar escaneo de puertos SYN silencioso (Nmap SYN scan)
# Alerta ante paquetes TCP con el bit SYN activo únicamente (típico escaneo de reconocimiento)
alert tcp any any -> $HOME_NET any (msg:"SYN Scan Detectado (Intento de Reconocimiento)"; flags:S; sid:1000002; rev:1;)

# 3. Regla opcional para detectar intentos de conexión externa a SSH no autorizados
alert tcp any any -> $HOME_NET 2222 (msg:"Intento de conexion SSH detectado"; flags:S; sid:1000003; rev:1;)
